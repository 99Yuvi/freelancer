APP_NAME=Operalyn
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=false
APP_URL=https://api.operalyn.com
FRONTEND_URL=https://operalyn.com

BCRYPT_ROUNDS=12
LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (get from Hostinger hPanel → Databases) ──────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=                      # e.g. u697460761_operalyn
DB_USERNAME=                      # e.g. u697460761_operalyn
DB_PASSWORD=                      # your DB password

# ── Session & Cache ──────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.operalyn.com      # leading dot = works on all subdomains
SANCTUM_STATEFUL_DOMAINS=operalyn.com,www.operalyn.com

CACHE_STORE=file
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# ── Mail (Hostinger free email or external SMTP) ──────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.operalyn.com       # or smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=noreply@operalyn.com
MAIL_PASSWORD=                    # your email password
MAIL_FROM_ADDRESS=noreply@operalyn.com
MAIL_FROM_NAME=Operalyn

# ── Razorpay ─────────────────────────────────────────────────────
RAZORPAY_KEY_ID=                  # rzp_live_xxxxxxxxx
RAZORPAY_KEY_SECRET=              # your live secret
RAZORPAY_WEBHOOK_SECRET=          # set in Razorpay dashboard → Webhooks

# ── Internal service auth (generate a strong random string) ──────
NODE_SERVICE_TOKEN=               # openssl rand -hex 32
